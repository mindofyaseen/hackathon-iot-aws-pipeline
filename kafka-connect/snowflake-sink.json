{
  "name": "snowflake-sink",
  "config": {
    "connector.class": "com.snowflake.kafka.connector.SnowflakeSinkConnector",
    "tasks.max": "1",
    "topics": "cdc.public.iot_events",
    "snowflake.url.name": "PLHVTTI-MWC64694.snowflakecomputing.com",
    "snowflake.user.name": "YASEEN",
    "snowflake.password": "${SNOWFLAKE_PASSWORD}",
    "snowflake.role.name": "ACCOUNTADMIN",
    "snowflake.database.name": "HACKATHON_IOT",
    "snowflake.schema.name": "RAW",
    "snowflake.topic2table.map": "cdc.public.iot_events:IOT_EVENTS",
    "buffer.count.records": "100",
    "buffer.flush.time": "30",
    "buffer.size.bytes": "5242880",
    "key.converter": "org.apache.kafka.connect.storage.StringConverter",
    "value.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter.schemas.enable": "false"
  }
}
